{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TreeState",
  "description": "The current state of the entire ThousandHand system",
  "type": "object",
  "properties": {
    "tree_id": {
      "type": "string",
      "description": "Unique identifier for this tree"
    },
    "assessed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this state was last assessed"
    },
    "oracle_version": {
      "type": "string",
      "description": "Version of the Oracle document"
    },
    "north_star_version": {
      "type": "string",
      "description": "Version of the North Star document"
    },
    "roots_health": {
      "type": "string",
      "enum": ["strong", "stable", "weak", "unknown"],
      "description": "Health of the roots (Oracle + North Star)"
    },
    "trunk_health": {
      "type": "string",
      "enum": ["strong", "stable", "weak", "unknown"],
      "description": "Health of the trunk (core systems)"
    },
    "branches": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Branch"
      }
    },
    "fruit_summary": {
      "type": "object",
      "description": "Summary of recent outcomes"
    },
    "soil": {
      "type": "object",
      "description": "Resources and constraints"
    }
  },
  "required": ["tree_id"],
  "definitions": {
    "Branch": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "hypothesis_id": { "type": "string" },
        "workflows": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "type": "string",
          "enum": ["proposed", "building", "active", "healthy", "underperforming", "failing", "prune_pending", "pruned", "archived"]
        },
        "planted_at": { "type": "string", "format": "date-time" },
        "expected_fruit": { "type": "object" },
        "actual_fruit": { "type": "object" },
        "last_fruit_check": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "hypothesis_id", "status"]
    }
  }
}
